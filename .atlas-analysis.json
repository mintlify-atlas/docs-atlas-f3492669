{
  "projectType": "saas",
  "projectName": "Simple Charts",
  "projectDescription": "A web app for educators to quickly create pie and bar charts from classroom data and export them as high-quality images.",
  "theme": "almond",
  "primaryColor": "#8b5cf6",
  "lightColor": "#a78bfa",
  "darkColor": "#7c3aed",
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "pages": ["introduction", "quickstart"]
          },
          {
            "group": "Features",
            "pages": [
              "features/chart-types",
              "features/data-entry",
              "features/color-themes",
              "features/export-options",
              "features/localization"
            ]
          },
          {
            "group": "Guides",
            "pages": [
