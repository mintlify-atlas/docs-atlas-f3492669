              "guides/pwa-installation",
              "guides/customization"
            ]
          }
        ]
      },
      {
        "tab": "Reference",
        "groups": [
          {
            "group": "Technical",
            "pages": [
              "reference/architecture",
              "reference/storage",
              "reference/configuration"
            ]
          }
        ]
      }
    ]
  },
  "keyFeatures": [
    "Pie and bar chart creation with simple data entry",
    "Curated color themes plus custom color picker",
    "PNG export at multiple resolutions with transparent or white backgrounds",
    "Local auto-save of worksheet data",
    "PWA-ready for installable app experience",
    "Bengali numeral support for localization"
  ],
  "publicApiSurface": [
    "ChartBuilderPage - Main chart creation interface",
    "DataTableEditor - Row-based data entry component",
    "ChartPreview - Real-time chart rendering with Chart.js",
    "ChartControlsPanel - Chart type, colors, and display options",
    "ExportActions - PNG export with resolution and background controls",
    "usePersistedState - Hook for localStorage auto-save",
    "useTheme - Hook for light/dark theme management",
    "CHART_PALETTES - Pre-defined color palette configurations",
    "validateRows - Data validation for chart generation",
    "downloadChartAsPng - Chart export utility"
  ]
}
